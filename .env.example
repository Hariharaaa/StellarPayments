# ── Analytics (PostHog) ────────────────────────────────────────────────────────
# Create a free project at https://posthog.com and paste your API key here.
# If not set, all analytics calls are silent no-ops.
VITE_POSTHOG_KEY=phc_your_api_key_here
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Error Tracking (Sentry) ────────────────────────────────────────────────────
# Create a free React project at https://sentry.io and paste your DSN here.
# If not set, Sentry is disabled (console errors still appear locally).
VITE_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/123456

# ── Feedback Collection (Formspree) ───────────────────────────────────────────
# Create a free form at https://formspree.io and paste the form ID here.
# The form ID is the part after /f/ in your Formspree endpoint URL.
# If not set, feedback submissions are logged to console (dev mode only).
VITE_FORMSPREE_ID=xpwzabcd
